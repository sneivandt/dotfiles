#!/usr/bin/env bash

# Guard against multiple sourcing
[ -n "$BASH_PROFILE_LOADED" ] && return
BASH_PROFILE_LOADED=1

# Global profile (optional)
[ -r /etc/profile ] && . /etc/profile

# Profile
[ -r ~/.config/shell/profile.sh ] && . ~/.config/shell/profile.sh

# GUI Profile (optional)
[ -r ~/.config/shell/profile-desktop.sh ] && . ~/.config/shell/profile-desktop.sh

# GUI Arch Profile (optional)
[ -r ~/.config/shell/profile-arch-desktop.sh ] && . ~/.config/shell/profile-arch-desktop.sh
