# Mako notification daemon configuration
# Migrated from dunst — Wayland-native replacement

font=Source Code Pro 10
background-color=#1a1a1a
text-color=#d0d0d0
border-color=#61afef
border-size=2
border-radius=4
width=300
# Maximum notification height before scrolling
height=300
margin=50,30
padding=10
anchor=top-right
default-timeout=10000

[urgency=critical]
background-color=#e06c75
text-color=#ffffff
default-timeout=0
