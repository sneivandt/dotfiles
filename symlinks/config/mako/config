# Mako notification daemon configuration
# Migrated from dunst — Wayland-native replacement

# Typography
font=Source Code Pro 11

# Geometry
width=380
height=200
margin=12,12
padding=14
anchor=top-right
border-size=2
border-radius=10
max-visible=3
layer=overlay

# Colors (Tokyo Night)
background-color=#1a1b26
text-color=#c0caf5
border-color=#7aa2f7

# Icons
max-icon-size=48
icon-location=left

# Behaviour
default-timeout=8000
group-by=app-name

# Progress bar (e.g. volume, brightness)
[category=progress]
border-color=#7aa2f7
default-timeout=2000
group-by=category

# Low urgency — subdued styling
[urgency=low]
background-color=#1a1b26
text-color=#9aa5ce
border-color=#414868
default-timeout=5000

# Critical urgency — prominent red, stays until dismissed
[urgency=critical]
background-color=#292e42
text-color=#f7768e
border-color=#f7768e
default-timeout=0
