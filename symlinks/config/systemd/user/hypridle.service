[Unit]
Description=Hypridle idle daemon

Wants=graphical-session.target
After=graphical-session.target

ConditionFileIsExecutable=/usr/bin/hypridle
ConditionPathExists=%h/.config/hypr/hypridle.conf

[Service]
Type=simple

ExecStart=/usr/bin/hypridle
Restart=on-failure
RestartSec=5
# The locker runs in its own transient unit so this daemon can remain sandboxed.
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=graphical-session.target
