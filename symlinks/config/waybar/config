{
    "layer": "top",
    "position": "top",
    "height": 26,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": [],
    "modules-right": ["custom/playing", "custom/stocks", "pulseaudio", "clock"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "●",
            "default": "○"
        },
        "on-click": "activate",
        "sort-by-number": true
    },

    "hyprland/window": {
        "max-length": 80,
        "tooltip": false
    },

    "pulseaudio": {
        "format": "\uf028 {volume:3}%",
        "format-muted": "\uf028   0%",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip": false
    },

    "clock": {
        "format": "\uf073 {:%d %b %H:%M}",
        "tooltip": false
    },

    "custom/playing": {
        "exec": "~/.config/hypr/scripts/playing.sh",
        "interval": 5,
        "format": "\uf001 {}"
    },

    "custom/stocks": {
        "exec": "~/.config/hypr/scripts/stocks.sh",
        "interval": 300,
        "return-type": "json",
        "tooltip": false
    }
}
