#!/usr/bin/env zsh

# Guard against multiple sourcing
[ -n "$ZSHRC_LOADED" ] && return
ZSHRC_LOADED=1

# Quiet
setopt no_beep
setopt NO_LIST_BEEP

# Word Style
autoload -Uz select-word-style
select-word-style bash

# History
setopt histignorealldups
setopt sharehistory
setopt extendedglob
setopt hist_expire_dups_first
setopt hist_find_no_dups
setopt hist_verify
[ -d ~/.cache/zsh ] || mkdir -p ~/.cache/zsh
HISTFILE=~/.cache/zsh/history
HISTSIZE=10000
SAVEHIST=10000

# Various options
setopt autocd
setopt autopushd
setopt pushdminus
setopt pushdsilent
setopt pushdtohome

# Path
[ -r ~/.config/shell/path.sh ] && . ~/.config/shell/path.sh

# Aliases
[ -r ~/.config/shell/aliases.sh ] && . ~/.config/shell/aliases.sh

# GUI Aliases (optional)
[ -r ~/.config/shell/aliases-desktop.sh ] && . ~/.config/shell/aliases-desktop.sh

# Prompt
[ -r ~/.config/zsh/prompt.zsh ] && . ~/.config/zsh/prompt.zsh

# Completion
[ -r ~/.config/zsh/completion.zsh ] && . ~/.config/zsh/completion.zsh

# Key bindings
[ -r ~/.config/zsh/key-bindings.zsh ] && . ~/.config/zsh/key-bindings.zsh

# Plugins
for plugin in ~/.config/zsh/plugins/*.zsh(N)
do
  . "$plugin"
done

# Performance: Cache system plugin paths to avoid repeated filesystem checks
# Only search for plugins if cache is stale (older than 24 hours)
typeset -g _ZSH_PLUGIN_CACHE="${HOME}/.cache/zsh/system-plugins.cache"
typeset -g _ZSH_PLUGIN_LIST=()

# Check cache freshness
# (#qNmh-24) = glob qualifier: quiet, no error if missing, modified less than 24 hours ago
if [[ -f "$_ZSH_PLUGIN_CACHE" && -n ${_ZSH_PLUGIN_CACHE}(#qNmh-24) ]]; then
  # Cache is fresh, load from cache
  source "$_ZSH_PLUGIN_CACHE"
else
  # Build cache
  typeset -ga _ZSH_PLUGIN_CANDIDATES=(
    /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
    /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
    /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
    /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
    /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
    /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  )

  _ZSH_PLUGIN_LIST=()
  for plugin in "${_ZSH_PLUGIN_CANDIDATES[@]}"; do
    if [[ -f "$plugin" ]]; then
      _ZSH_PLUGIN_LIST+=("$plugin")
    fi
  done

  # Save cache atomically to avoid partial writes
  cache_dir="${_ZSH_PLUGIN_CACHE%/*}"
  mkdir -p "$cache_dir" || return 1
  tmp_cache="$(mktemp "${_ZSH_PLUGIN_CACHE}.XXXXXX")" || return 1
  echo "typeset -ga _ZSH_PLUGIN_LIST=(" > "$tmp_cache"
  for plugin in "${_ZSH_PLUGIN_LIST[@]}"; do
    echo "  \"$plugin\"" >> "$tmp_cache"
  done
  echo ")" >> "$tmp_cache"
  mv "$tmp_cache" "$_ZSH_PLUGIN_CACHE"
fi

# Load cached plugins
for plugin in "${_ZSH_PLUGIN_LIST[@]}"; do
  source "$plugin"
done

# zoxide
if command -v zoxide >/dev/null 2>&1
then
  eval "$(zoxide init zsh)"
fi

# FZF (optional)
[ -f /usr/share/fzf/key-bindings.zsh ] && . /usr/share/fzf/key-bindings.zsh
[ -f /usr/share/fzf/completion.zsh ] && . /usr/share/fzf/completion.zsh

# Functions
fpath=(~/.config/zsh/functions $fpath)
for func in ~/.config/zsh/functions/*(N)
do
  autoload -Uz "${func:t}"
done

# Custom FZF Ctrl+R behavior: Execute immediately
if zle -l fzf-history-widget
then
  fzf-history-widget-accept() {
    fzf-history-widget
    if [[ $? -eq 0 ]]
    then
      zle accept-line
    fi
  }
  zle -N fzf-history-widget-accept
  bindkey '^R' fzf-history-widget-accept
fi
